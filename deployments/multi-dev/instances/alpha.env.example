# Filename stem and instance identity must match.
TRACECAT_INSTANCE=alpha
PORT=8100

# Per-instance database, Temporal namespace, buckets, and Redis database.
TRACECAT__DB_URI=postgresql+psycopg://postgres:postgres@tracecat-shared-postgres:5432/alpha
TEMPORAL__CLUSTER_NAMESPACE=alpha
TRACECAT__BLOB_STORAGE_BUCKET_WORKFLOW=alpha-tracecat-workflow
TRACECAT__BLOB_STORAGE_BUCKET_ATTACHMENTS=alpha-tracecat-attachments
TRACECAT__BLOB_STORAGE_BUCKET_REGISTRY=alpha-tracecat-registry
TRACECAT__BLOB_STORAGE_BUCKET_SKILLS=alpha-tracecat-skills
TRACECAT__BLOB_STORAGE_BUCKET_AGENT=alpha-tracecat-agent
REDIS_URL=redis://tracecat-shared-redis:6379/0

# Per-instance internal and browser-visible URLs.
TRACECAT__API_URL=http://127.0.0.1:8100
TRACECAT__PUBLIC_API_URL=http://localhost:8100/api
TRACECAT__PUBLIC_APP_URL=http://localhost:8100
TRACECAT__ALLOW_ORIGINS=http://localhost:8100

# Replace all four values with unique secrets for this instance.
TRACECAT__DB_ENCRYPTION_KEY=replace-with-an-alpha-fernet-key
TRACECAT__SERVICE_KEY=replace-with-an-alpha-service-key
TRACECAT__SIGNING_SECRET=replace-with-an-alpha-signing-secret
USER_AUTH_SECRET=replace-with-an-alpha-user-auth-secret
