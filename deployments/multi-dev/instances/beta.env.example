# Filename stem and instance identity must match.
TRACECAT_INSTANCE=beta
PORT=8101

# Per-instance database, Temporal namespace, buckets, and Redis database.
TRACECAT__DB_URI=postgresql+psycopg://postgres:postgres@tracecat-shared-postgres:5432/beta
TEMPORAL__CLUSTER_NAMESPACE=beta
TRACECAT__BLOB_STORAGE_BUCKET_WORKFLOW=beta-tracecat-workflow
TRACECAT__BLOB_STORAGE_BUCKET_ATTACHMENTS=beta-tracecat-attachments
TRACECAT__BLOB_STORAGE_BUCKET_REGISTRY=beta-tracecat-registry
TRACECAT__BLOB_STORAGE_BUCKET_SKILLS=beta-tracecat-skills
TRACECAT__BLOB_STORAGE_BUCKET_AGENT=beta-tracecat-agent
REDIS_URL=redis://tracecat-shared-redis:6379/1

# Per-instance internal and browser-visible URLs.
TRACECAT__API_URL=http://127.0.0.1:8101
TRACECAT__PUBLIC_API_URL=http://localhost:8101/api
TRACECAT__PUBLIC_APP_URL=http://localhost:8101
TRACECAT__ALLOW_ORIGINS=http://localhost:8101

# Replace all four values with unique secrets for this instance.
TRACECAT__DB_ENCRYPTION_KEY=replace-with-a-beta-fernet-key
TRACECAT__SERVICE_KEY=replace-with-a-beta-service-key
TRACECAT__SIGNING_SECRET=replace-with-a-beta-signing-secret
USER_AUTH_SECRET=replace-with-a-beta-user-auth-secret
