# Instance identity and dedicated host ports
TRACECAT_INSTANCE=alpha
TRACECAT_API_PORT=8101
TRACECAT_UI_PORT=3101
TRACECAT_REDIS_DB=1

# Browser-visible URLs. Change localhost to the VPS hostname when appropriate.
TRACECAT_PUBLIC_API_URL=http://localhost:8101/api
TRACECAT_PUBLIC_APP_URL=http://localhost:3101
TRACECAT_MINIO_PUBLIC_URL=http://localhost:9000

# Shared infrastructure credentials; these must match the infra stack.
TRACECAT__POSTGRES_USER=postgres
TRACECAT__POSTGRES_PASSWORD=postgres
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=password

# Replace all four values before starting an instance.
TRACECAT__DB_ENCRYPTION_KEY=replace-with-a-fernet-key
TRACECAT__SERVICE_KEY=replace-with-a-random-service-key
TRACECAT__SIGNING_SECRET=replace-with-a-random-signing-secret
USER_AUTH_SECRET=replace-with-a-random-user-auth-secret

LOG_LEVEL=INFO
TRACECAT__AUTH_TYPES=basic
TRACECAT__AUTH_SUPERADMIN_EMAIL=dev@example.com
TRACECAT__FEATURE_FLAGS=
TRACECAT__EE_MULTI_TENANT=false
TRACECAT__STANDALONE_RUN_MIGRATIONS=true

# Small-instance memory and concurrency defaults
MALLOC_ARENA_MAX=2
TEMPORAL__THREADPOOL_MAX_WORKERS=4
TEMPORAL__MAX_CONCURRENT_ACTIVITIES=8
TEMPORAL__MAX_CONCURRENT_WORKFLOW_TASKS=4
TRACECAT__EXECUTOR_MAX_CONCURRENT_ACTIVITIES=8
TRACECAT__EXECUTOR_THREADPOOL_MAX_WORKERS=4
TRACECAT__AGENT_MAX_CONCURRENT_ACTIVITIES=4
TRACECAT__AGENT_EXECUTOR_MAX_CONCURRENT_ACTIVITIES=1

TRACECAT__EXECUTOR_BACKEND=direct
TRACECAT__DISABLE_NSJAIL=true
TEMPORAL__DISABLE_EAGER_ACTIVITY_EXECUTION=true
TEMPORAL__PAYLOAD_ENCRYPTION_ENABLED=false
TRACECAT__DISABLE_PRESIGNED_URL_IP_CHECKING=true
TRACECAT__RESULT_EXTERNALIZATION_ENABLED=true
TRACECAT__COLLECTION_MANIFESTS_ENABLED=true
TRACECAT__LOCAL_REPOSITORY_ENABLED=false

# Optional external services
TRACECAT__LITELLM_BASE_URL=http://host.docker.internal:4000
SENTRY_DSN=
